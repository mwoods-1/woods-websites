 in one flow.\"}]]}],\"$L4\",\"$L5\",\"$undefined\"]}],\"$L6\",\"$L7\"]}],[\"$L8\"],\"$L9\"]}],\"isPartial\":false,\"staleTime\":300,\"varyParams\":null,\"buildId\":\"ut2SIDtbjiRWcINl3XMzi\"}\n4:[\"$\",\"div\",null,{\"className\":\"my-16 border-t\",\"style\":{\"borderColor\":\"rgba(255,255,255,0.06)\"}}]\n5:[\"$\",\"div\",null,{\"className\":\"grid gap-16 md:grid-cols-[1fr_2fr]\",\"children\":[[\"$\",\"div\",null,{\"children\":[\"$\",\"p\",null,{\"className\":\"font-mono text-xs tracking-[0.25em] uppercase\",\"style\":{\"color\":\"var(--accent)\"},\"children\":\"The Result\"}]}],[\"$\",\"p\",null,{\"className\":\"font-sans text-base leading-relaxed md:text-lg\",\"style\":{\"color\":\"rgba(255,255,255,0.7)\"},\"children\":\"Brae now has a professional online presence that matches the quality of his coaching. Parents can browse programs, check availability, and book sessions directly through the site. The integrated booking and payment system has streamlined his operations, cutting out the manual back-and-forth and letting him focus on coaching.\"}]]}]\n6:[\"$\",\"section\",null,{\"className\":\"border-t\",\"style\":{\"borderColor\":\"rgba(255,255,255,0.08)\"},\"children\":[\"$\",\"div\",null,{\"className\":\"mx-auto grid max-w-5xl md:grid-cols-2\",\"children\":[[\"$\",\"$L3\",null,{\"href\":\"/work/svens-basecamp\",\"className\":\"group flex flex-col gap-2 border-b p-8 transition-colors duration-300 hover:bg-white/[0.02] md:border-b-0 md:border-r md:p-12\",\"style\":{\"borderColor\":\"rgba(255,255,255,0.08)\"},\"children\":[[\"$\",\"span\",null,{\"className\":\"font-mono text-xs tracking-wide\",\"style\":{\"color\":\"rgba(255,255,255,0.3)\"},\"children\":\"← Previous\"}],[\"$\",\"span\",null,{\"className\":\"font-display text-lg font-bold tracking-tight transition-colors duration-300 group-hover:text-white\",\"style\":{\"color\":\"rgba(255,255,255,0.6)\"},\"children\":\"Sven's Basecamp Hostel\"}]]}],[\"$\",\"$L3\",null,{\"href\":\"/work/kingdom-property-care\",\"clas