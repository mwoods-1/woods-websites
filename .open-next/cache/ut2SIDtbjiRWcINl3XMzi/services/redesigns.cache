ounded-full transition-all duration-500\" style=\"width:40px;height:40px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.12);box-shadow:none;transform:scale(1)\"><span class=\"font-mono text-[10px] font-bold\" style=\"color:rgba(255,255,255,0.28)\">03</span></div><span class=\"font-mono text-xs tracking-widest uppercase transition-colors duration-500\" style=\"color:rgba(255,255,255,0.22)\">Build</span></button><div class=\"ml-5 w-px transition-colors duration-500\" style=\"height:20px;background:rgba(255,255,255,0.08)\"></div></div><div class=\"flex flex-col\"><button class=\"flex items-center gap-4 py-2.5 text-left focus:outline-none\"><div class=\"flex-none flex items-center justify-center rounded-full transition-all duration-500\" style=\"width:40px;height:40px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.12);box-shadow:none;transform:scale(1)\"><span class=\"font-mono text-[10px] font-bold\" style=\"color:rgba(255,255,255,0.28)\">04</span></div><span class=\"font-mono text-xs tracking-widest uppercase transition-colors duration-500\" style=\"color:rgba(255,255,255,0.22)\">Launch</span></button><div class=\"ml-5 w-px transition-colors duration-500\" style=\"height:20px;background:rgba(255,255,255,0.08)\"></div></div><div class=\"flex flex-col\"><button class=\"flex items-center gap-4 py-2.5 text-left focus:outline-none\"><div class=\"flex-none flex items-center justify-center rounded-full transition-all duration-500\" style=\"width:40px;height:40px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.12);box-shadow:none;transform:scale(1)\"><span class=\"font-mono text-[10px] font-bold\" style=\"color:rgba(255,255,255,0.28)\">05</span></div><span class=\"font-mono text-xs tracking-widest uppercase transition-colors duration-500\" style=\"color:rgba(255,255,255,0.22)\">Support</span></button></div></div><p class=\"font-sans text-base leading-relaxed md:text-lg\" style=\"color:rgba(255,255,255,0.5);max-width:600px;opacity:0;transform:translateY(14px)\">We start with a free discovery call to understand your business, your goals, and what success looks like. No jargon, no pressure, just an honest conversation that shapes everything we build together.</p><div class=\"flex items-center gap-2 mt-10\"><button class=\"rounded-full transition-all duration-300 focus:outline-none\" style=\"height:4px;width:28px;background:var(--accent)\"></button><button class=\"rounded-full transition-all duration-300 focus:outline-none\" style=\"height:4px;width:6px;background:rgba(255,255,255,0.15)\"></button><button class=\"rounded-full transition-all duration-300 focus:outline-none\" style=\"height:4px;width:6px;background:rgba(255,255,255,0.15)\"></button><button class=\"rounded-full transition-all duration-300 focus:outline-none\" style=\"height:4px;width:6px;background:rgba(255,255,255,0.15)\"></button><button class=\"rounded-full transition-all duration-300 focus:outline-none\" style=\"height:4px;width:6px;background:rgba(255,255,255,0.15)\"></button><span class=\"ml-3 font-mono text-[10px] tracking-widest uppercase\" style=\"color:rgba(255,255,255,0.2)\">Auto</span></div><div class=\"absolute bottom-0 left-0 h-[2px]\" style=\"background:var(--accent);opacity:0.4;width:0%\"></div></div></section><section class=\"border-t pb-24\" style=\"border-color:rgba(255,255,255,0.08)\"><div class=\"mx-auto max-w-5xl px-6 pt-16\"><p class=\"mb-3 font-mono text-xs tracking-[0.25em] uppercase\" style=\"color:var(--accent)\">The Work</p><h2 class=\"mb-16 font-display text-3xl font-bold tracking-tight sm:text-4xl\" style=\"color:var(--text)\">Before &amp; after</h2><div class=\"space-y-16\"><div><p class=\"mb-4 font-display text-lg font-bold tracking-tight\" style=\"color:rgba(255,255,255,0.7)\">Sven&#x27;s Basecamp</p><div class=\"relative w-full select-none overflow-hidden rounded-2xl\" style=\"aspect-ratio:16/10;cursor:col-resize;border:1px solid rgba(255,255,255,0.08)\"><img alt=\"Sven&#x27;s