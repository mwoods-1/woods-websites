-size-adjust\" content=\"\"/><title>About | Woods Websites</title><meta name=\"description\" content=\"Meet Sean and Mark Woods, two brothers who build custom, high-performance websites for businesses that care about quality.\"/><link rel=\"manifest\" href=\"/manifest.json\"/><meta property=\"og:title\" content=\"Woods Websites | Custom Web Design &amp; Development\"/><meta property=\"og:description\" content=\"Custom-built, high-performance websites crafted with care. Tailored to your goals, built to perform.\"/><meta property=\"og:image\" content=\"https://woodswebsites.com/images/logo/og-image.png\"/><meta property=\"og:image:width\" content=\"1200\"/><meta property=\"og:image:height\" content=\"630\"/><meta name=\"twitter:card\" content=\"summary_large_image\"/><meta name=\"twitter:title\" content=\"Woods Websites | Custom Web Design &amp; Development\"/><meta name=\"twitter:description\" content=\"Custom-built, high-performance websites crafted with care. Tailored to your goals, built to perform.\"/><meta name=\"twitter:image\" content=\"https://woodswebsites.com/images/logo/og-image.png\"/><meta name=\"twitter:image:width\" content=\"1200\"/><meta name=\"twitter:image:height\" content=\"630\"/><link rel=\"icon\" href=\"/images/logo/favicon.svg\" type=\"image/svg+xml\"/><link rel=\"icon\" href=\"/images/logo/favicon-32.png\" sizes=\"32x32\" type=\"image/png\"/><link rel=\"icon\" href=\"/images/logo/favicon-16.png\" sizes=\"16x16\" type=\"image/png\"/><link rel=\"apple-touch-icon\" href=\"/images/logo/apple-touch-icon.png\" sizes=\"180x180\"/><script src=\"/_next/static/chunks/03~yq9q893hmn.js\" noModule=\"\"></script></head><body class=\"antialiased\"><div hidden=\"\"><!--$--><!--/$--></div><header class=\"fixed top-0 left-0 right-0 z-50 transition-all duration-500\" style=\"opacity:1;pointer-events:auto;transform:translateY(0)\"><div class=\"mx-auto flex max-w-7xl items-center justify-between px-6 py-5\"><a class=\"group flex items-center gap-2\" href=\"/\"><span class=\"font-display text-lg font-bold\" style=\"color:var(--text);letter-spacing:-0.04em\">WOODS WEBSITES<span style=\"color:var(--accent)\">.</span></span></a><nav class=\"hidden items-center gap-8 md:flex\"><a class=\"group relative font-sans text-sm tracking-wide transition-colors duration-300\" style=\"color:rgba(255,255,255,0.6)\" href=\"/work\"><span class=\"transition-colors duration-300 group-hover:text-white\">Work</span><span class=\"absolute -bottom-0.5 left-0 h-px w-0 transition-all duration-300 group-hover:w-full\" style=\"background:var(--accent)\"></span></a><a class=\"group relative font-sans text-sm tracking-wide transition-colors duration-300\" style=\"color:rgba(255,255,255,0.6)\" href=\"/services\"><span class=\"transition-colors duration-300 group-hover:text-white\">Services</span><span class=\"absolute -bottom-0.5 left-0 h-px w-0 transition-all duration-300 group-hover:w-full\" style=\"background:var(--accent)\"></span></a><a class=\"group relative font-sans text-sm tracking-wide transition-colors duration-300\" style=\"color:rgba(255,255,255,0.6)\" href=\"/about\"><span class=\"transition-colors duration-300 group-hover:text-white\">About</span><span class=\"absolute -bottom-0.5 left-0 h-px w-0 transition-all duration-300 group-hover:w-full\" style=\"background:var(--accent)\"></span></a><a class=\"rounded-full border px-5 py-2 font-sans text-sm font-medium text-[var(--text)] transition-all duration-300 hover:bg-white hover:!text-black\" style=\"border-color:rgba(255,255,255,0.2)\" href=\"/contact\">Contact Us</a></nav><button class=\"flex flex-col gap-1.5 md:hidden\" aria-label=\"Toggle menu\"><span class=\"block h-px w-6 transition-all duration-300\" style=\"background:var(--text);transform:none\"></span><span class=\"block h-px w-6 transition-all duration-300\" style=\"background:var(--text);opacity:1\"></span><span class=\"block h-px w-6 transition-all duration-300\" style=\"background:var(--text);transform:none\"></span></button></div><div class=\"overflow-hidden transition-all duration-500 md:hidden\" style=\"max-height:0;background:rgba(5,5,5,0.97);border-top:1px solid transparent\"><nav class=\"flex flex-col px-6 py-4\"><a class=\"border-b py-4 font-sans text-sm tracking-wide\" style=\"color:rgba(255,255,255,0.7);border-color:rgba(255,255,255,0.06)\" href=\"/work\">Work</a><a class=\"border-b py-4 font-sans text-sm tracking-wide\" style=\"color:rgba(255,255,255,0.7);border-color:rgba(255,255,255,0.06)\" href=\"/services\">Services</a><a class=\"border-b py-4 font-sans text-sm tracking-wide\" style=\"color:rgba(255,255,255,0.7);border-color:rgba(255,255,255,0.06)\" href=\"/about\">About</a><a class=\"mt-4 rounded-full py-3 text-center font-sans text-sm font-medium\" style=\"background:var(--accent);color:#050505\" href=\"/contact\">Contact Us</a></nav></div></header><div class=\"fixed bottom-4 right-4 sm:bottom-6 sm:right-6 md:bottom-8 md:right-8 z-50 transition-all duration-500\" style=\"opacity:0;pointer-events:none;transform:translateY(16px)\"><a href=\"/contact\" class=\"block rounded-full px-7 py-4 font-sans text-base font-semibold\" tabindex=\"0\" style=\"background:var(--accent);color:#050505;box-shadow:0 4px 24px rgba(46,196,182,0.35)\">Contact Us</a></div><main><section class=\"relative overflow-hidden pt-28 pb-14 sm:pt-36 sm:pb-20 md:pt-48 md:pb-28\"><div class=\"pointer-events-none absolute inset-0\" style=\"background:radial-gradient(ellipse 50% 50% at 50% 0%, rgba(46,196,182,0.05), transparent)\"></div><div class=\"relative mx-auto max-w-7xl px-6\" style=\"opacity:1;transform:none\"><p class=\"mb-4 font-mono text-xs tracking-[0.25em] uppercase\" style=\"color:var(--accent)\">Who We Are</p><h1 class=\"font-display text-4xl font-bold leading-tight tracking-tight sm:text-5xl md:text-6xl lg:text-7xl\" style=\"color:var(--text)\">About <span style=\"color:var(--accent)\">Us</span></h1><p class=\"mt-6 max-w-xl font-sans text-base leading-relaxed md:text-lg\" style=\"color:rgba(255,255,255,0.5)\">Two brothers. High-performance websites. Tailored to your needs. Delivered with precision.</p></div></section><section class=\"mx-auto max-w-7xl px-6 pb-28\"><div class=\"grid gap-0 lg:grid-cols-[1fr_1fr] lg:gap-16 xl:grid-cols-[5fr_6fr]\"><div class=\"relative mb-12 lg:mb-0\" style=\"opacity:0;transform:translateY(40px)\"><div class=\"absolute -left-3 top-8 h-32 w-px\" style=\"background:linear-gradient(to bottom, var(--accent), transparent)\"></div><div class=\"relative overflow-hidden rounded-2xl\" style=\"box-shadow:0 0 0 1px rgba(46,196,182,0.12), 0 32px 64px rgba(0,0,0,0.6)\"><img alt=\"Sean and Mark Woods, founders of Woods Websites\" width=\"700\" height=\"700\" decoding=\"async\" data-nimg=\"1\" class=\"w-full object-cover\" style=\"color:transparent\" srcSet=\"/_next/image?url=%2Fimages%2Ffounders_about_photo.png&amp;w=750&amp;q=75 1x, /_next/image?url=%2Fimages%2Ffounders_about_photo.png&amp;w=1920&amp;q=75 2x\" src=\"/_next/image?url=%2Fimages%2Ffounders_about_photo.png&amp;w=1920&amp;q=75\"/><div class=\"pointer-events-none absolute bottom-0 left-0 right-0 h-40\" style=\"background:linear-gradient(to top, rgba(5,5,5,0.7) 0%, transparent 100%)\"></div><div class=\"absolute bottom-6 left-6 right-6\"><p class=\"font-mono text-xs tracking-[0.2em] uppercase\" style=\"color:var(--accent)\">Sean &amp; Mark Woods</p><p class=\"mt-1 font-sans text-sm\" style=\"color:rgba(255,255,255,0.5)\">Co-founders, Woods Websites</p></div></div></div><div class=\"flex flex-col justify-center\" style=\"opacity:0;transform:translateY(40px)\"><p class=\"mb-4 font-mono text-xs tracking-[0.25em] uppercase\" style=\"color:var(--accent)\">Our Story</p><h2 class=\"mb-8 font-display text-3xl font-bold leading-tight tracking-tight sm:text-4xl lg:text-[2.6rem]\" style=\"color:var(--text)\">Two brothers.<br/>One obsession:<br/><span style=\"color:var(--accent)\">building it right.</span></h2><div class=\"space-y-5\"><p class=\"font-sans text-base leading-relaxed\" style=\"color:rgba(255,255,255,0.65)\">Woods Websites is run by Sean and Mark Woods, two brothers who share an obsession with building things properly. We started building websites because we kept seeing businesses stuck with slow, outdated sites that didn&#x27;t reflect the quality of what they actually do.</p><p class=\"font-sans text-base leading-relaxed\" style=\"color:rgba(255,255,255,0.65)\">We&#x27;re not a big agency. We don&#x27;t have account managers or project coordinators standing between you and the people doing the work. When you hire us, you work directly with us, the people designing, building, and maintaining your site.</p><p class=\"font-sans text-base leading-relaxed\" style=\"color:rgba(255,255,255,0.65)\">That matters because it means faster communication, better decisions, and a final product that actually matches what you had in mind. We treat every project like it&#x27;s our own, because our name is on it.</p></div><div class=\"mt-10 flex gap-6 border-t pt-8 sm:gap-10\" style=\"border-color:rgba(255,255,255,0.08)\"><div><p class=\"font-display text-2xl font-bold\" style=\"color:var(--accent)\">↑</p><p class=\"mt-0.5 font-mono text-xs tracking-wide uppercase\" style=\"color:rgba(255,255,255,0.35)\">Traffic &amp; bookings</p></div><div><p class=\"font-display text-2xl font-bold\" style=\"color:var(--accent)\">0</p><p class=\"mt-0.5 font-mono text-xs tracking-wide uppercase\" style=\"color:rgba(255,255,255,0.35)\">Middlemen</p></div><div><p class=\"font-display text-2xl font-bold\" style=\"color:var(--accent)\">Free</p><p class=\"mt-0.5 font-mono text-xs tracking-wide uppercase\" style=\"color:rgba(255,255,255,0.35)\">Discovery call</p></div></div></div></div></section><section class=\"border-t py-28\" style=\"border-color:rgba(255,255,255,0.08)\"><div class=\"mx-auto max-w-7xl px-6\"><div style=\"opacity:0;transform:translateY(40px)\"><p class=\"mb-3 font-mono text-xs tracking-[0.25em] uppercase\" style=\"color:var(--accent)\">How We Work</p><h2 class=\"mb-16 font-display text-3xl font-bold tracking-tight sm:text-4xl\" style=\"color:var(--text)\">What we believe in</h2></div><div class=\"grid gap-px sm:grid-cols-2\"><div style=\"opacity:0;transform:translateY(40px)\"><div class=\"group relative border-t p-8 transition-colors duration-300 md:p-10\" style=\"border-color:rgba(255,255,255,0.06)\"><div class=\"pointer-events-none absolute inset-0 opacity-0 transition-opacity duration-300 group-hover:opacity-100\" style=\"background:linear-gradient(135deg, rgba(46,196,182,0.03) 0%, transparent 60%)\"></div><p class=\"mb-4 font-mono text-xs tracking-[0.2em]\" style=\"color:rgba(255,255,255,0.2)\">01</p><h3 class=\"mb-3 font-display text-xl font-bold tracking-tight transition-colors duration-300 group-hover:text-[var(--accent)]\" style=\"color:var(--text)\">Quality over quantity</h3><p class=\"font-sans text-sm leading-relaxed\" style=\"color:rgba(255,255,255,0.45)\">We take on a small number of projects at a time so every client gets our full attention. No assembly lines, no rushing to the next job.</p></div></div><div style=\"opacity:0;transform:translateY(40px)\"><div class=\"group relative border-t p-8 transition-colors duration-300 md:p-10\" style=\"border-color:rgba(255,255,255,0.06)\"><div class=\"pointer-events-none absolute inset-0 opacity-0 transition-opacity duration-300 group-hover:opacity-100\" style=\"background:linear-gradient(135deg, rgba(46,196,182,0.03) 0%, transparent 60%)\"></div><p class=\"mb-4 font-mono text-xs tracking-[0.2em]\" style=\"color:rgba(255,255,255,0.2)\">02</p><h3 class=\"mb-3 font-display text-xl font-bold tracking-tight transition-colors duration-300 group-hover:text-[var(--accent)]\" style=\"color:var(--text)\">Fit for purpose</h3><p class=\"font-sans text-sm leading-relaxed\" style=\"color:rgba(255,255,255,0.45)\">We match the approach to the project. Whether that&#x27;s a fully custom build or a well-configured template, we focus on what delivers the best outcome for your goals and budget.</p></div></div><div style=\"opacity:0;transform:translateY(40px)\"><div class=\"group relative border-t p-8 transition-colors duration-300 md:p-10\" style=\"border-color:rgba(255,255,255,0.06)\"><div class=\"pointer-events-none absolute inset-0 opacity-0 transition-opacity duration-300 group-hover:opacity-100\" style=\"background:linear-gradient(135deg, rgba(46,196,182,0.03) 0%, transparent 60%)\"></div><p class=\"mb-4 font-mono text-xs tracking-[0.2em]\" style=\"color:rgba(255,255,255,0.2)\">03</p><h3 class=\"mb-3 font-display text-xl font-bold tracking-tight transition-colors duration-300 group-hover:text-[var(--accent)]\" style=\"color:var(--text)\">Built to perform</h3><p class=\"font-sans text-sm leading-relaxed\" style=\"color:rgba(255,255,255,0.45)\">Fast load times, clean code, mobile-first design, and proper SEO. We don&#x27;t just make things look good. We make them work.</p></div></div><div style=\"opacity:0;transform:translateY(40px)\"><div class=\"group relative border-t p-8 transition-colors duration-300 md:p-10\" style=\"border-color:rgba(255,255,255,0.06)\"><div class=\"pointer-events-none absolute inset-0 opacity-0 transition-opacity duration-300 group-hover:opacity-100\" style=\"background:linear-gradient(135deg, rgba(46,196,182,0.03) 0%, transparent 60%)\"></div><p class=\"mb-4 font-mono text-xs tracking-[0.2em]\" style=\"color:rgba(255,255,255,0.2)\">04</p><h3 class=\"mb-3 font-display text-xl font-bold tracking-tight transition-colors duration-300 group-hover:text-[var(--accent)]\" style=\"color:var(--text)\">Ongoing partnership</h3><p class=\"font-sans text-sm leading-relaxed\" style=\"color:rgba(255,255,255,0.45)\">We don&#x27;t disappear after launch. We&#x27;re here for updates, improvements, and support for as long as you need us.</p></div></div></div></div></section><section class=\"border-t py-28\" style=\"border-color:rgba(255,255,255,0.08)\"><div class=\"mx-auto max-w-7xl px-6\"><div style=\"opacity:0;transform:translateY(40px)\"><p class=\"mb-3 font-mono text-xs tracking-[0.25em] uppercase\" style=\"color:var(--accent)\">Our Tools</p><h2 class=\"mb-12 font-display text-3xl font-bold tracking-tight sm:text-4xl\" style=\"color:var(--text)\">Built with modern tech</h2></div><div class=\"relative overflow-hidden\" style=\"mask-image:linear-gradient(to right, transparent, black 8%, black 92%, transparent);-webkit-mask-image:linear-gradient(to right, transparent, black 8%, black 92%, transparent)\"><div class=\"flex w-max gap-6 py-4\"><span class=\"group relative flex-none overflow-hidden rounded-full border px-5 py-2.5 font-mono text-xs tracking-wide whitespace-nowrap transition-all duration-300 hover:border-[rgba(46,196,182,0.4)]\" style=\"border-color:rgba(255,255,255,0.1);color:rgba(255,255,255,0.5)\"><span class=\"pointer-events-none absolute inset-0 opacity-0 transition-opacity duration-300 group-hover:opacity-100\" style=\"background:radial-gradient(circle at center, rgba(46,196,182,0.08), transparent 70%)\"></span><span class=\"relative transition-colors duration-300 group-hover:text-[var(--accent)]\">Next.js</span></span><span class=\"group relative flex-none overflow-hidden rounded-full border px-5 py-2.5 font-mono text-xs tracking-wide whitespace-nowrap transition-all duration-300 hover:border-[rgba(46,196,182,0.4)]\" style=\"border-color:rgba(255,255,255,0.1);color:rgba(255,255,255,0.5)\"><span class=\"pointer-events-none absolute inset-0 opacity-0 transition-opacity duration-300 group-hover:opacity-100\" style=\"background:radial-gradient(circle at center, rgba(46,196,182,0.08), transparent 70%)\"></span><span class=\"relative transition-colors duration-300 group-hover:text-[var(--accent)]\">React</span></span><span class=\"group relative flex-none overflow-hidden rounded-full border px-5 py-2.5 font-mono text-xs tracking-wide whitespace-nowrap transition-all duration-300 hover:border-[rgba(46,196,182,0.4)]\" style=\"border-color:rgba(255,255,255,0.1);color:rgba(255,255,255,0.5)\"><span class=\"pointer-events-none absolute inset-0 opacity-0 transition-opacity duration-300 group-hover:opacity-100\" style=\"background:radial-gradient(circle at center, rgba(46,196,182,0.08), transparent 70%)\"></span><span class=\"relative transition-colors duration-300 group-hover:text-[var(--accent)]\">TypeScript</span></span><span class=\"group relative flex-none overflow-hidden rounded-full border px-5 py-2.5 font-mono text-xs tracking-wide whitespace-nowrap transition-all duration-300 hover:border-[rgba(46,196,182,0.4)]\" style=\"border-color:rgba(255,255,255,0.1);color:rgba(255,255,255,0.5)\"><span class=\"pointer-events-none absolute inset-0 opacity-0 transition-opacity duration-300 group-hover:opacity-100\" style=\"background:radial-gradient(circle at center, rgba(46,196,182,0.08), transparent 70%)\"></span><span class=\"relative transition-colors duration-300 group-hover:text-[var(--accent)]\">Tailwind CSS</span></span><span class=\"group relative flex-none overflow-hidden rounded-full border px-5 py-2.5 font-mono text-xs tracking-wide whitespace-nowrap transition-all duration-300 hover:border-[rgba(46,196,182,0.4)]\" style=\"border-color:rgba(255,255,255,0.1);color:rgba(255,255,255,0.5)\"><span class=\"pointer-events-none absolute inset-0 opacity-0 transition-opacity duration-300 group-hover:opacity-100\" style=\"background:radial-gradient(circle at center, rgba(46,196,182,0.08), transparent 70%)\"></span><span class=\"relative transition-colors duration-300 group-hover:text-[var(--accent)]\">Vercel</span></span><span class=\"group relative flex-none overflow-hidden rounded-full border px-5 py-2.5 font-mono text-xs tracking-wide whitespace-nowrap transition-all duration-300 hover:border-[rgba(46,196,182,0.4)]\" style=\"border-color:rgba(255,255,255,0.1);color:rgba(255,255,255,0.5)\"><span class=\"pointer-events-none absolute inset-0 opacity-0 transition-opacity duration-300 group-hover:opacity-100\" style=\"background:radial-gradient(circle at center, r